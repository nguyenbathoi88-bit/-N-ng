<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lịch trình du lịch Đà Nẵng - Hội An - Huế</title>
    <!-- Tailwind CSS for styling -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8fafc; }
        .smooth-scroll { scroll-behavior: smooth; }
        /* Cấu hình màu cho từng buổi */
        .time-sang { background-color: #fffbeb; color: #d97706; border-color: #fde68a; }
        .time-trua { background-color: #ecfdf5; color: #059669; border-color: #a7f3d0; }
        .time-chieu { background-color: #f0f9ff; color: #0284c7; border-color: #bae6fd; }
        .time-toi { background-color: #eef2ff; color: #4f46e5; border-color: #c7d2fe; }
    </style>
</head>
<body class="smooth-scroll text-slate-800">

    <!-- Hero Section -->
    <header class="relative h-[40vh] min-h-[300px] flex items-center justify-center bg-cover bg-center bg-no-repeat shadow-lg" 
            style="background-image: linear-gradient(to bottom, rgba(15, 23, 42, 0.4), rgba(15, 23, 42, 0.8)), url('https://images.unsplash.com/photo-1559592413-7cec4d0cae2b?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80');">
        <div class="relative z-10 text-center px-4">
            <span class="inline-block py-1 px-3 rounded-full bg-blue-500/80 text-white text-sm font-semibold mb-4 tracking-wider uppercase border border-blue-400">Hành trình di sản</span>
            <h1 class="text-4xl md:text-5xl font-bold text-white mb-2 shadow-sm">Đà Nẵng - Hội An - Huế</h1>
            <p class="text-xl text-slate-200 mt-2 font-light"><i class="far fa-calendar-alt mr-2"></i>25 Tháng 4 - 28 Tháng 4</p>
        </div>
    </header>

    <!-- Navigation / Quick Jump -->
    <nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-md shadow-sm border-b border-slate-200">
        <div class="max-w-4xl mx-auto px-4 py-3 flex overflow-x-auto gap-2 md:justify-center no-scrollbar">
            <a href="#day1" class="whitespace-nowrap px-4 py-2 rounded-full bg-slate-100 hover:bg-blue-100 hover:text-blue-700 text-sm font-medium transition"><i class="fas fa-map-marker-alt mr-1"></i> Ngày 25/4 (Đà Nẵng)</a>
            <a href="#day2" class="whitespace-nowrap px-4 py-2 rounded-full bg-slate-100 hover:bg-blue-100 hover:text-blue-700 text-sm font-medium transition"><i class="fas fa-map-marker-alt mr-1"></i> Ngày 26/4 (Hội An)</a>
            <a href="#day3" class="whitespace-nowrap px-4 py-2 rounded-full bg-slate-100 hover:bg-blue-100 hover:text-blue-700 text-sm font-medium transition"><i class="fas fa-map-marker-alt mr-1"></i> Ngày 27/4 (Huế)</a>
            <a href="#day4" class="whitespace-nowrap px-4 py-2 rounded-full bg-slate-100 hover:bg-blue-100 hover:text-blue-700 text-sm font-medium transition"><i class="fas fa-map-marker-alt mr-1"></i> Ngày 28/4 (Về HCM)</a>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="max-w-4xl mx-auto px-4 py-10 space-y-12">

        <!-- NGÀY 1 -->
        <section id="day1" class="scroll-mt-20">
            <h2 class="text-2xl font-bold text-slate-800 border-b-2 border-blue-500 pb-2 mb-6 flex items-center">
                <span class="bg-blue-500 text-white w-10 h-10 rounded-full flex items-center justify-center mr-3 text-lg">1</span>
                Ngày 25/04 (Thứ 6) - Chào Đà Nẵng
            </h2>
            
            <div class="space-y-4">
                <!-- Chiều -->
                <div class="flex flex-col md:flex-row bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-md transition duration-300 group">
                    <div class="md:w-36 time-chieu flex flex-col justify-center items-center py-5 border-b md:border-b-0 md:border-r shrink-0">
                        <i class="fas fa-plane-arrival text-3xl mb-2 group-hover:scale-110 transition-transform"></i>
                        <span class="font-bold text-lg">Buổi Chiều</span>
                        <span class="text-xs mt-1 font-medium bg-white/50 px-2 py-0.5 rounded-full">15:00 - 17:30</span>
                    </div>
                    <div class="p-5 flex-1">
                        <h3 class="text-xl font-bold text-slate-800 mb-2">Đến Đà Nẵng - Dạo biển Mỹ Khê</h3>
                        <p class="text-slate-600 mb-4">Đáp chuyến bay từ TP.HCM đến Đà Nẵng. Di chuyển về khách sạn nhận phòng, cất hành lý và nghỉ ngơi nhẹ. Ra tắm biển Mỹ Khê và ngắm hoàng hôn tuyệt đẹp.</p>
                        <div class="flex flex-wrap gap-2 text-sm">
                            <span class="bg-slate-100 text-slate-600 px-3 py-1 rounded-full"><i class="fas fa-car mr-1 text-slate-400"></i> Di chuyển: Taxi/Grab (15-20p)</span>
                            <span class="bg-slate-100 text-slate-600 px-3 py-1 rounded-full"><i class="fas fa-ticket-alt mr-1 text-slate-400"></i> Vé: Không yêu cầu</span>
                        </div>
                    </div>
                </div>

                <!-- Tối -->
                <div class="flex flex-col md:flex-row bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-md transition duration-300 group">
                    <div class="md:w-36 time-toi flex flex-col justify-center items-center py-5 border-b md:border-b-0 md:border-r shrink-0">
                        <i class="fas fa-fish text-3xl mb-2 group-hover:scale-110 transition-transform"></i>
                        <span class="font-bold text-lg">Buổi Tối</span>
                        <span class="text-xs mt-1 font-medium bg-white/50 px-2 py-0.5 rounded-full">18:30 - 21:00</span>
                    </div>
                    <div class="p-5 flex-1">
                        <h3 class="text-xl font-bold text-slate-800 mb-2">Tiệc nhậu hải sản ven biển</h3>
                        <p class="text-slate-600 mb-4">Thưởng thức hải sản tươi sống đặc trưng của Đà Nẵng dọc theo đường Võ Nguyên Giáp hoặc đường Nguyễn Văn Thoại.</p>
                        <div class="flex flex-wrap gap-2 text-sm">
                            <span class="bg-orange-50 text-orange-600 px-3 py-1 rounded-full border border-orange-100"><i class="fas fa-utensils mr-1"></i> Gợi ý: Quán Bé Mặn / Năm Rảnh</span>
                            <span class="bg-slate-100 text-slate-600 px-3 py-1 rounded-full"><i class="fas fa-info-circle mr-1 text-slate-400"></i> Nên đặt bàn trước nếu đi đông</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- NGÀY 2 -->
        <section id="day2" class="scroll-mt-20">
            <h2 class="text-2xl font-bold text-slate-800 border-b-2 border-teal-500 pb-2 mb-6 flex items-center">
                <span class="bg-teal-500 text-white w-10 h-10 rounded-full flex items-center justify-center mr-3 text-lg">2</span>
                Ngày 26/04 (Thứ 7) - Đà Nẵng & Phố cổ Hội An
            </h2>
            
            <div class="space-y-4">
                <!-- Sáng -->
                <div class="flex flex-col md:flex-row bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-md transition duration-300 group">
                    <div class="md:w-36 time-sang flex flex-col justify-center items-center py-5 border-b md:border-b-0 md:border-r shrink-0">
                        <i class="fas fa-mountain-sun text-3xl mb-2 group-hover:scale-110 transition-transform"></i>
                        <span class="font-bold text-lg">Buổi Sáng</span>
                        <span class="text-xs mt-1 font-medium bg-white/50 px-2 py-0.5 rounded-full">08:00 - 11:30</span>
                    </div>
                    <div class="p-5 flex-1">
                        <h3 class="text-xl font-bold text-slate-800 mb-2">Bán đảo Sơn Trà & Chùa Linh Ứng</h3>
                        <p class="text-slate-600 mb-4">Viếng tượng Phật Bà Quan Âm cao 67m, ngắm toàn cảnh thành phố biển Đà Nẵng từ trên cao.</p>
                        <div class="flex flex-wrap gap-2 text-sm">
                            <span class="bg-slate-100 text-slate-600 px-3 py-1 rounded-full"><i class="fas fa-motorcycle mr-1 text-slate-400"></i> Di chuyển: Thuê xe máy/Taxi</span>
                            <span class="bg-orange-50 text-orange-600 px-3 py-1 rounded-full border border-orange-100"><i class="fas fa-utensils mr-1"></i> Ăn sáng: Bún chả cá Nguyễn Chí Thanh</span>
                        </div>
                    </div>
                </div>

                <!-- Trưa -->
                <div class="flex flex-col md:flex-row bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-md transition duration-300 group">
                    <div class="md:w-36 time-trua flex flex-col justify-center items-center py-5 border-b md:border-b-0 md:border-r shrink-0">
                        <i class="fas fa-utensils text-3xl mb-2 group-hover:scale-110 transition-transform"></i>
                        <span class="font-bold text-lg">Buổi Trưa</span>
                        <span class="text-xs mt-1 font-medium bg-white/50 px-2 py-0.5 rounded-full">12:00 - 13:30</span>
                    </div>
                    <div class="p-5 flex-1">
                        <h3 class="text-xl font-bold text-slate-800 mb-2">Đặc sản Bánh tráng cuốn thịt heo</h3>
                        <p class="text-slate-600 mb-4">Nghỉ ngơi và nạp năng lượng với món đặc sản trứ danh của Đà Nẵng.</p>
                        <div class="flex flex-wrap gap-2 text-sm">
                            <span class="bg-orange-50 text-orange-600 px-3 py-1 rounded-full border border-orange-100"><i class="fas fa-map-marker-alt mr-1"></i> Quán Trần hoặc Quán Mậu</span>
                        </div>
                    </div>
                </div>

                <!-- Chiều -->
                <div class="flex flex-col md:flex-row bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-md transition duration-300 group">
                    <div class="md:w-36 time-chieu flex flex-col justify-center items-center py-5 border-b md:border-b-0 md:border-r shrink-0">
                        <i class="fas fa-gopuram text-3xl mb-2 group-hover:scale-110 transition-transform"></i>
                        <span class="font-bold text-lg">Buổi Chiều</span>
                        <span class="text-xs mt-1 font-medium bg-white/50 px-2 py-0.5 rounded-full">14:30 - 17:30</span>
                    </div>
                    <div class="p-5 flex-1">
                        <h3 class="text-xl font-bold text-slate-800 mb-2">Ngũ Hành Sơn & Tiến về Hội An</h3>
                        <p class="text-slate-600 mb-4">Khám phá các hang động tại Danh thắng Ngũ Hành Sơn. Sau đó di chuyển vào Hội An, dạo bước qua Chùa Cầu, Nhà cổ Tân Ký, hội quán.</p>
                        <div class="flex flex-wrap gap-2 text-sm">
                            <span class="bg-red-50 text-red-600 px-3 py-1 rounded-full border border-red-100"><i class="fas fa-ticket-alt mr-1"></i> Ngũ Hành Sơn: ~40k/vé</span>
                            <span class="bg-red-50 text-red-600 px-3 py-1 rounded-full border border-red-100"><i class="fas fa-ticket-alt mr-1"></i> Phố cổ Hội An: 80k/vé tuyến</span>
                            <span class="bg-slate-100 text-slate-600 px-3 py-1 rounded-full"><i class="fas fa-shoe-prints mr-1 text-slate-400"></i> Nên đi giày thể thao</span>
                        </div>
                    </div>
                </div>

                <!-- Tối -->
                <div class="flex flex-col md:flex-row bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-md transition duration-300 group">
                    <div class="md:w-36 time-toi flex flex-col justify-center items-center py-5 border-b md:border-b-0 md:border-r shrink-0">
                        <i class="fas fa-lantern text-3xl mb-2 group-hover:scale-110 transition-transform"></i>
                        <span class="font-bold text-lg">Buổi Tối</span>
                        <span class="text-xs mt-1 font-medium bg-white/50 px-2 py-0.5 rounded-full">18:00 - 21:00</span>
                    </div>
                    <div class="p-5 flex-1">
                        <h3 class="text-xl font-bold text-slate-800 mb-2">Hội An về đêm & Thả hoa đăng</h3>
                        <p class="text-slate-600 mb-4">Thưởng thức Cao Lầu hoặc Cơm gà Hội An. Ngồi thuyền mộc thả hoa đăng trên sông Hoài. Uống trà mót. Sau đó lên xe quay lại Đà Nẵng nghỉ ngơi.</p>
                        <div class="flex flex-wrap gap-2 text-sm">
                            <span class="bg-orange-50 text-orange-600 px-3 py-1 rounded-full border border-orange-100"><i class="fas fa-utensils mr-1"></i> Cơm gà Bà Buội / Nước Mót</span>
                            <span class="bg-red-50 text-red-600 px-3 py-1 rounded-full border border-red-100"><i class="fas fa-ship mr-1"></i> Thuyền sông Hoài: ~150k/thuyền (Mua tại bến)</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- NGÀY 3 -->
        <section id="day3" class="scroll-mt-20">
            <h2 class="text-2xl font-bold text-slate-800 border-b-2 border-purple-500 pb-2 mb-6 flex items-center">
                <span class="bg-purple-500 text-white w-10 h-10 rounded-full flex items-center justify-center mr-3 text-lg">3</span>
                Ngày 27/04 (Chủ Nhật) - Khám phá Cố Đô Huế
            </h2>
            
            <div class="space-y-4">
                <!-- Sáng -->
                <div class="flex flex-col md:flex-row bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-md transition duration-300 group">
                    <div class="md:w-36 time-sang flex flex-col justify-center items-center py-5 border-b md:border-b-0 md:border-r shrink-0">
                        <i class="fas fa-archway text-3xl mb-2 group-hover:scale-110 transition-transform"></i>
                        <span class="font-bold text-lg">Buổi Sáng</span>
                        <span class="text-xs mt-1 font-medium bg-white/50 px-2 py-0.5 rounded-full">07:30 - 12:00</span>
                    </div>
                    <div class="p-5 flex-1">
                        <h3 class="text-xl font-bold text-slate-800 mb-2">Đèo Hải Vân & Đại Nội Huế</h3>
                        <p class="text-slate-600 mb-4">Khởi hành từ Đà Nẵng đi Huế. Bạn có thể chọn đi hầm hoặc trải nghiệm đường đèo Hải Vân. Khám phá Hoàng thành, Tử Cấm Thành - dấu ấn triều Nguyễn.</p>
                        <div class="flex flex-wrap gap-2 text-sm">
                            <span class="bg-red-50 text-red-600 px-3 py-1 rounded-full border border-red-100"><i class="fas fa-ticket-alt mr-1"></i> Vé Đại Nội: ~200k/người (mua tại cổng)</span>
                            <span class="bg-slate-100 text-slate-600 px-3 py-1 rounded-full"><i class="fas fa-headphones mr-1 text-slate-400"></i> Khuyên dùng: Nên thuê HDV tại điểm</span>
                        </div>
                    </div>
                </div>

                <!-- Trưa -->
                <div class="flex flex-col md:flex-row bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-md transition duration-300 group">
                    <div class="md:w-36 time-trua flex flex-col justify-center items-center py-5 border-b md:border-b-0 md:border-r shrink-0">
                        <i class="fas fa-bowl-food text-3xl mb-2 group-hover:scale-110 transition-transform"></i>
                        <span class="font-bold text-lg">Buổi Trưa</span>
                        <span class="text-xs mt-1 font-medium bg-white/50 px-2 py-0.5 rounded-full">12:30 - 14:00</span>
                    </div>
                    <div class="p-5 flex-1">
                        <h3 class="text-xl font-bold text-slate-800 mb-2">Ẩm thực cung đình & Dân dã</h3>
                        <p class="text-slate-600 mb-4">Nghỉ ngơi và thưởng thức hương vị đặc trưng của xứ Huế.</p>
                        <div class="flex flex-wrap gap-2 text-sm">
                            <span class="bg-orange-50 text-orange-600 px-3 py-1 rounded-full border border-orange-100"><i class="fas fa-utensils mr-1"></i> Bún bò Huế, Bánh bèo, nậm, lọc</span>
                        </div>
                    </div>
                </div>

                <!-- Chiều -->
                <div class="flex flex-col md:flex-row bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-md transition duration-300 group">
                    <div class="md:w-36 time-chieu flex flex-col justify-center items-center py-5 border-b md:border-b-0 md:border-r shrink-0">
                        <i class="fas fa-place-of-worship text-3xl mb-2 group-hover:scale-110 transition-transform"></i>
                        <span class="font-bold text-lg">Buổi Chiều</span>
                        <span class="text-xs mt-1 font-medium bg-white/50 px-2 py-0.5 rounded-full">14:30 - 17:30</span>
                    </div>
                    <div class="p-5 flex-1">
                        <h3 class="text-xl font-bold text-slate-800 mb-2">Chùa Thiên Mụ & Lăng Khải Định</h3>
                        <p class="text-slate-600 mb-4">Viếng Chùa Thiên Mụ cổ kính bên dòng sông Hương. Tham quan Lăng Khải Định với kiến trúc giao thoa Á - Âu độc đáo. Sau đó lên xe về lại Đà Nẵng.</p>
                        <div class="flex flex-wrap gap-2 text-sm">
                            <span class="bg-red-50 text-red-600 px-3 py-1 rounded-full border border-red-100"><i class="fas fa-ticket-alt mr-1"></i> Lăng Khải Định: ~150k/vé</span>
                            <span class="bg-green-50 text-green-600 px-3 py-1 rounded-full border border-green-100"><i class="fas fa-gift mr-1"></i> Mua quà: Mè xửng, Trà cung đình</span>
                        </div>
                    </div>
                </div>

                <!-- Tối -->
                <div class="flex flex-col md:flex-row bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-md transition duration-300 group">
                    <div class="md:w-36 time-toi flex flex-col justify-center items-center py-5 border-b md:border-b-0 md:border-r shrink-0">
                        <i class="fas fa-bridge text-3xl mb-2 group-hover:scale-110 transition-transform"></i>
                        <span class="font-bold text-lg">Buổi Tối</span>
                        <span class="text-xs mt-1 font-medium bg-white/50 px-2 py-0.5 rounded-full">18:30 - 21:00</span>
                    </div>
                    <div class="p-5 flex-1">
                        <h3 class="text-xl font-bold text-slate-800 mb-2">Chill tại Đà Nẵng</h3>
                        <p class="text-slate-600 mb-4">Về đến Đà Nẵng, ăn tối nhẹ nhàng với Mì Quảng. Tự do dạo biển đêm, đi chợ đêm Sơn Trà mua sắm đồ lưu niệm hoặc ngắm Cầu Rồng, Cầu Tình Yêu.</p>
                        <div class="flex flex-wrap gap-2 text-sm">
                            <span class="bg-orange-50 text-orange-600 px-3 py-1 rounded-full border border-orange-100"><i class="fas fa-utensils mr-1"></i> Ăn tối: Mì Quảng Ếch Bếp Trang</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- NGÀY 4 -->
        <section id="day4" class="scroll-mt-20">
            <h2 class="text-2xl font-bold text-slate-800 border-b-2 border-emerald-500 pb-2 mb-6 flex items-center">
                <span class="bg-emerald-500 text-white w-10 h-10 rounded-full flex items-center justify-center mr-3 text-lg">4</span>
                Ngày 28/04 (Thứ 2) - Tạm biệt Miền Trung
            </h2>
            
            <div class="space-y-4">
                <!-- Sáng -->
                <div class="flex flex-col md:flex-row bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-md transition duration-300 group">
                    <div class="md:w-36 time-sang flex flex-col justify-center items-center py-5 border-b md:border-b-0 md:border-r shrink-0">
                        <i class="fas fa-bag-shopping text-3xl mb-2 group-hover:scale-110 transition-transform"></i>
                        <span class="font-bold text-lg">Buổi Sáng</span>
                        <span class="text-xs mt-1 font-medium bg-white/50 px-2 py-0.5 rounded-full">08:00 - 11:00</span>
                    </div>
                    <div class="p-5 flex-1">
                        <h3 class="text-xl font-bold text-slate-800 mb-2">Mua sắm đặc sản làm quà</h3>
                        <p class="text-slate-600 mb-4">Ghé Chợ Hàn hoặc Chợ Cồn để mua chả bò, mực rim me, cá khô, mắm nêm làm quà mang về. Sau đó thư giãn tại quán cafe ngắm sông Hàn.</p>
                        <div class="flex flex-wrap gap-2 text-sm">
                            <span class="bg-slate-100 text-slate-600 px-3 py-1 rounded-full"><i class="fas fa-wallet mr-1 text-slate-400"></i> Mẹo: Nhớ trả giá khi mua sắm tại chợ</span>
                            <span class="bg-orange-50 text-orange-600 px-3 py-1 rounded-full border border-orange-100"><i class="fas fa-utensils mr-1"></i> Ăn sáng: Bún mắm nêm</span>
                        </div>
                    </div>
                </div>

                <!-- Trưa -->
                <div class="flex flex-col md:flex-row bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden hover:shadow-md transition duration-300 group">
                    <div class="md:w-36 time-trua flex flex-col justify-center items-center py-5 border-b md:border-b-0 md:border-r shrink-0">
                        <i class="fas fa-suitcase-rolling text-3xl mb-2 group-hover:scale-110 transition-transform"></i>
                        <span class="font-bold text-lg">Buổi Trưa</span>
